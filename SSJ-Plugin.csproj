<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <GenerateRuntimeConfigurationFiles>false</GenerateRuntimeConfigurationFiles>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MySqlConnector" Version="2.3.7" />
    <PackageReference Include="CounterStrikeSharp.API" Version="1.0.364">
      <PrivateAssets>none</PrivateAssets>
      <ExcludeAssets>runtime</ExcludeAssets>
      <IncludeAssets>compile; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <Reference Include="T3MenuSharedAPI">
      <HintPath>..\T3Menu-API-main\BuildOutput\shared\T3MenuSharedAPI\T3MenuSharedAPI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="SharpTimerAPI">
      <HintPath>..\SharpTimer-personal - BHOP NEW PROJECT\SharpTimerAPI\build\SharpTimerAPI.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
